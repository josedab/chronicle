# Auto-detect text files and ensure LF line endings
* text=auto eol=lf

# Go source files
*.go text eol=lf

# Explicitly declare text files
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.mod text eol=lf
*.sum text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf

# Binary files
*.wasm binary
*.png binary
*.jpg binary
*.ico binary
