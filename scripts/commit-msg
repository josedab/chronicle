#!/usr/bin/env bash
# scripts/commit-msg — Git commit-msg hook for Chronicle
#
# Enforces conventional commit message format.
# Install with: make install-hooks
#
set -euo pipefail

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE")

# Allow merge commits
if echo "$COMMIT_MSG" | grep -qE '^Merge '; then
  exit 0
fi

# Conventional commit pattern: type(optional-scope): description
PATTERN='^(feat|fix|docs|test|refactor|perf|chore|ci|build)(\(.+\))?: .+'

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo "ERROR: Commit message does not follow Conventional Commits format."
  echo ""
  echo "  Expected: <type>: <description>"
  echo "  Got:      $COMMIT_MSG"
  echo ""
  echo "  Valid types: feat, fix, docs, test, refactor, perf, chore, ci, build"
  echo "  Example:     feat: add query caching support"
  echo ""
  echo "  See: https://www.conventionalcommits.org/"
  exit 1
fi
