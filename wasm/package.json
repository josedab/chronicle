{
  "name": "@chronicle-db/wasm",
  "version": "0.1.0",
  "description": "Chronicle time-series database - WebAssembly build",
  "main": "chronicle.js",
  "types": "chronicle.d.ts",
  "files": [
    "chronicle.wasm",
    "chronicle.js",
    "chronicle.d.ts",
    "wasm_exec.js"
  ],
  "scripts": {
    "build": "GOOS=js GOARCH=wasm go build -o chronicle.wasm ./main.go",
    "build:tinygo": "tinygo build -o chronicle.wasm -target wasm ./main.go"
  },
  "keywords": ["time-series", "database", "wasm", "embedded", "chronicle"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/chronicle-db/chronicle"
  }
}
