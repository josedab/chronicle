{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "make check",
      "type": "shell",
      "command": "make check",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$go"],
      "detail": "Pre-commit validation: preflight + vet + fast tests (~15s)"
    },
    {
      "label": "make test-fast",
      "type": "shell",
      "command": "make test-fast",
      "group": "test",
      "problemMatcher": ["$go"],
      "detail": "Internal package tests only (~5s)"
    },
    {
      "label": "make lint",
      "type": "shell",
      "command": "make lint",
      "group": "build",
      "problemMatcher": ["$go"],
      "detail": "Run go vet + golangci-lint"
    },
    {
      "label": "make cover",
      "type": "shell",
      "command": "make cover",
      "group": "test",
      "problemMatcher": ["$go"],
      "detail": "Print coverage summary (warns if below 70%)"
    }
  ]
}
