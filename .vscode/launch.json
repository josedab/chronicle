{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run HTTP Server Example",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/examples/http-server"
    },
    {
      "name": "Debug Current Test File",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}",
      "args": ["-test.v", "-test.run", "${selectedText}"]
    },
    {
      "name": "Run CLI",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/chronicle"
    }
  ]
}
