{
  "__inputs": [
    {
      "name": "DS_CHRONICLE",
      "label": "Chronicle",
      "description": "Chronicle time-series database",
      "type": "datasource",
      "pluginId": "chronicle-datasource"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Write Throughput (points/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "chronicle-datasource", "uid": "${DS_CHRONICLE}" },
          "queryText": "SELECT rate(value) FROM chronicle_writes_total WINDOW 1m",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "title": "Query Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "chronicle-datasource", "uid": "${DS_CHRONICLE}" },
          "queryText": "SELECT max(value) FROM chronicle_query_duration_seconds WINDOW 1m",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "title": "Storage Size",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "chronicle-datasource", "uid": "${DS_CHRONICLE}" },
          "queryText": "SELECT last(value) FROM chronicle_storage_bytes",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "Active Metrics",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "chronicle-datasource", "uid": "${DS_CHRONICLE}" },
          "queryText": "SELECT last(value) FROM chronicle_metrics_count",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Partition Count",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "chronicle-datasource", "uid": "${DS_CHRONICLE}" },
          "queryText": "SELECT last(value) FROM chronicle_partitions_count",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "WAL Size",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "chronicle-datasource", "uid": "${DS_CHRONICLE}" },
          "queryText": "SELECT last(value) FROM chronicle_wal_bytes",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "Points Written Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "chronicle-datasource", "uid": "${DS_CHRONICLE}" },
          "queryText": "SELECT sum(value) FROM chronicle_points_written WINDOW 5m",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "title": "Active Alerts",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "chronicle-datasource", "uid": "${DS_CHRONICLE}" },
          "queryText": "SELECT * FROM chronicle_active_alerts LIMIT 50",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["chronicle", "tsdb", "monitoring"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Chronicle TSDB Overview",
  "uid": "chronicle-overview",
  "version": 1
}
